NODE_ENV=development
PORT=4000
API_PORT=4000
WEB_PORT=5173
APP_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173
API_URL=http://localhost:4000

DATABASE_URL=postgresql://crm:crm_password@localhost:5432/telegram_crm?schema=public

JWT_SECRET=replace-with-at-least-32-random-characters
ENCRYPTION_KEY=replace-with-32-byte-base64-key
ADMIN_BOOTSTRAP_EMAIL=tu-correo@example.com
ADMIN_BOOTSTRAP_PASSWORD=crea-una-contrasena-larga-y-unica

TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_telegram_api_hash
TELEGRAM_SESSION_LABEL=primary
TELEGRAM_SYNC_LIMIT=1000
TELEGRAM_SYNC_MESSAGE_LIMIT=30

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

MEDIA_STORAGE=database
MEDIA_LOCAL_DIR=storage/media
MEDIA_MAX_MB=8
WORKER_POLL_INTERVAL_MS=10000
WORKER_MAX_SEND_ATTEMPTS=3
WORKER_PROCESSING_LOCK_MS=300000
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

DEFAULT_TIMEZONE=America/La_Paz
GLOBAL_AI_ENABLED=false
GLOBAL_CAMPAIGNS_ENABLED=true
